      "expectations": [
        {"type": "exact", "path": "primary_owner", "value": "service-a"},
        {"type": "exact", "path": "implementation_owner", "value": "service-a"},
        {"type": "array_contains", "path": "feature_intents", "value": "api"},
        {"type": "exact", "path": "ui_change_needed", "value": false},
        {"type": "exact", "path": "requires_human_approval", "value": true}
      ]
