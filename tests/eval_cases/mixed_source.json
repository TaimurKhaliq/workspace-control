        {"type": "exact", "path": "db_change_needed", "value": false},
        {"type": "exact", "path": "api_change_needed", "value": true},
        {"type": "exact", "path": "ui_change_needed", "value": true},
        {"type": "exact", "path": "requires_human_approval", "value": true}
      ]
    },
    {
      "id": "ui-new-field-persisted",
      "command": "plan-feature",
      "feature": "Add preferred language to the customer profile form and persist it",
      "expectations": [
        {"type": "exact", "path": "primary_owner", "value": "service-a"},
        {"type": "exact", "path": "implementation_owner", "value": "web-ui"},
